<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>7-Day Deficit Diet Plan</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Literata:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #f5f0e8;
    --surface: #ede8dc;
    --card: #ffffff;
    --border: #d8d0c0;
    --ink: #1a1612;
    --muted: #7a7060;
    --accent: #c84b2f;
    --green: #2d6a4f;
    --gold: #c9882a;
    --blue: #2c5f8a;
    --tag-bg: #f0ebe0;
  }

- { margin: 0; padding: 0; box-sizing: border-box; }

body {
background: var(–bg);
color: var(–ink);
font-family: ‘Literata’, Georgia, serif;
min-height: 100vh;
}

/* Grain texture overlay */
body::after {
content: ‘’;
position: fixed;
inset: 0;
background-image: url(“data:image/svg+xml,%3Csvg viewBox=‘0 0 256 256’ xmlns=‘http://www.w3.org/2000/svg’%3E%3Cfilter id=‘noise’%3E%3CfeTurbulence type=‘fractalNoise’ baseFrequency=‘0.9’ numOctaves=‘4’ stitchTiles=‘stitch’/%3E%3C/filter%3E%3Crect width=‘100%25’ height=‘100%25’ filter=‘url(%23noise)’ opacity=‘0.04’/%3E%3C/svg%3E”);
pointer-events: none;
z-index: 999;
opacity: 0.4;
}

.page {
max-width: 860px;
margin: 0 auto;
padding: 48px 24px 100px;
}

/* Header */
.masthead {
border-top: 3px solid var(–ink);
border-bottom: 1px solid var(–ink);
padding: 24px 0 20px;
margin-bottom: 40px;
display: grid;
grid-template-columns: 1fr auto;
gap: 20px;
align-items: end;
animation: fadeIn 0.7s ease both;
}

.masthead-label {
font-family: ‘Syne’, sans-serif;
font-size: 10px;
letter-spacing: 4px;
text-transform: uppercase;
color: var(–accent);
margin-bottom: 8px;
}

.masthead h1 {
font-family: ‘Syne’, sans-serif;
font-size: clamp(36px, 8vw, 72px);
font-weight: 800;
line-height: 0.95;
letter-spacing: -1px;
color: var(–ink);
}

.masthead-meta {
text-align: right;
font-size: 12px;
color: var(–muted);
font-style: italic;
line-height: 1.8;
}

/* Stats strip */
.stats-strip {
display: grid;
grid-template-columns: repeat(4, 1fr);
border: 1px solid var(–border);
border-radius: 4px;
overflow: hidden;
margin-bottom: 40px;
animation: fadeIn 0.7s 0.1s ease both;
}

.stat-cell {
padding: 16px;
text-align: center;
border-right: 1px solid var(–border);
background: var(–card);
}

.stat-cell:last-child { border-right: none; }

.stat-n {
font-family: ‘Syne’, sans-serif;
font-size: 28px;
font-weight: 800;
line-height: 1;
}

.stat-l {
font-size: 10px;
color: var(–muted);
text-transform: uppercase;
letter-spacing: 2px;
margin-top: 4px;
}

.stat-cell:nth-child(1) .stat-n { color: var(–accent); }
.stat-cell:nth-child(2) .stat-n { color: var(–green); }
.stat-cell:nth-child(3) .stat-n { color: var(–gold); }
.stat-cell:nth-child(4) .stat-n { color: var(–blue); }

/* Why not losing weight box */
.warning-box {
background: var(–ink);
color: var(–bg);
border-radius: 6px;
padding: 20px 24px;
margin-bottom: 40px;
animation: fadeIn 0.7s 0.15s ease both;
}

.warning-box h3 {
font-family: ‘Syne’, sans-serif;
font-size: 14px;
letter-spacing: 2px;
text-transform: uppercase;
color: var(–gold);
margin-bottom: 10px;
}

.warning-box p {
font-size: 13px;
line-height: 1.7;
color: #d8d0c0;
}

.warning-box strong { color: #fff; }

/* Day navigation */
.day-nav {
display: grid;
grid-template-columns: repeat(7, 1fr);
gap: 6px;
margin-bottom: 28px;
animation: fadeIn 0.7s 0.2s ease both;
}

.day-btn {
padding: 10px 4px;
background: var(–card);
border: 1px solid var(–border);
border-radius: 4px;
cursor: pointer;
text-align: center;
transition: all 0.15s;
font-family: ‘Syne’, sans-serif;
}

.day-btn .day-short {
font-size: 9px;
letter-spacing: 2px;
text-transform: uppercase;
color: var(–muted);
display: block;
}

.day-btn .day-num {
font-size: 18px;
font-weight: 800;
color: var(–ink);
display: block;
line-height: 1.2;
}

.day-btn.active, .day-btn:hover {
background: var(–ink);
border-color: var(–ink);
}

.day-btn.active .day-short,
.day-btn.active .day-num,
.day-btn:hover .day-short,
.day-btn:hover .day-num {
color: var(–bg);
}

/* Day panel */
.day-panel { display: none; animation: slideIn 0.3s ease both; }
.day-panel.active { display: block; }

@keyframes slideIn {
from { opacity: 0; transform: translateY(10px); }
to { opacity: 1; transform: translateY(0); }
}

/* Day header */
.day-header {
display: flex;
justify-content: space-between;
align-items: center;
margin-bottom: 20px;
padding-bottom: 16px;
border-bottom: 2px solid var(–ink);
}

.day-title {
font-family: ‘Syne’, sans-serif;
font-size: 28px;
font-weight: 800;
}

.day-macros {
display: flex;
gap: 16px;
font-family: ‘Syne’, sans-serif;
font-size: 12px;
}

.macro { text-align: center; }
.macro-val { font-size: 20px; font-weight: 700; display: block; line-height: 1; }
.macro-lbl { font-size: 9px; letter-spacing: 1px; text-transform: uppercase; color: var(–muted); }

/* Meal card */
.meal {
background: var(–card);
border: 1px solid var(–border);
border-radius: 6px;
margin-bottom: 14px;
overflow: hidden;
}

.meal-top {
display: grid;
grid-template-columns: 4px 1fr;
}

.meal-stripe { background: var(–accent); }
.meal-stripe.lunch { background: var(–gold); }
.meal-stripe.dinner { background: var(–green); }
.meal-stripe.breakfast { background: var(–blue); }

.meal-body { padding: 18px 20px; }

.meal-row1 {
display: flex;
justify-content: space-between;
align-items: flex-start;
margin-bottom: 12px;
flex-wrap: wrap;
gap: 8px;
}

.meal-time {
font-family: ‘Syne’, sans-serif;
font-size: 9px;
letter-spacing: 3px;
text-transform: uppercase;
color: var(–muted);
margin-bottom: 3px;
}

.meal-name {
font-family: ‘Syne’, sans-serif;
font-size: 17px;
font-weight: 700;
color: var(–ink);
}

.meal-pills {
display: flex;
gap: 6px;
flex-wrap: wrap;
}

.pill {
font-family: ‘Syne’, sans-serif;
font-size: 11px;
font-weight: 600;
padding: 3px 10px;
border-radius: 100px;
white-space: nowrap;
}

.pill-p { background: rgba(45,106,79,0.12); color: var(–green); border: 1px solid rgba(45,106,79,0.2); }
.pill-c { background: rgba(201,136,42,0.12); color: var(–gold); border: 1px solid rgba(201,136,42,0.2); }
.pill-k { background: rgba(200,75,47,0.12); color: var(–accent); border: 1px solid rgba(200,75,47,0.2); }
.pill-q { background: rgba(44,95,138,0.1); color: var(–blue); border: 1px solid rgba(44,95,138,0.2); }

.ingredients-grid {
display: flex;
flex-wrap: wrap;
gap: 6px;
margin-bottom: 12px;
}

.ingr {
background: var(–tag-bg);
border: 1px solid var(–border);
border-radius: 4px;
padding: 5px 10px;
font-size: 12.5px;
}

.ingr em {
font-style: normal;
color: var(–muted);
font-size: 11px;
margin-left: 3px;
}

.tip {
font-size: 12px;
color: var(–muted);
font-style: italic;
border-left: 2px solid var(–border);
padding-left: 10px;
line-height: 1.6;
}

/* Quick tag */
.quick-tag {
display: inline-block;
font-family: ‘Syne’, sans-serif;
font-size: 9px;
letter-spacing: 1px;
text-transform: uppercase;
padding: 2px 7px;
border-radius: 3px;
margin-left: 8px;
vertical-align: middle;
background: rgba(44,95,138,0.1);
color: var(–blue);
border: 1px solid rgba(44,95,138,0.2);
}

/* Daily note */
.daily-note {
background: var(–surface);
border: 1px solid var(–border);
border-radius: 6px;
padding: 14px 18px;
font-size: 13px;
color: var(–muted);
font-style: italic;
margin-top: 8px;
line-height: 1.7;
}

/* Rules section */
.rules-section {
margin-top: 50px;
border-top: 3px double var(–ink);
padding-top: 32px;
animation: fadeIn 0.7s 0.3s ease both;
}

.rules-title {
font-family: ‘Syne’, sans-serif;
font-size: 22px;
font-weight: 800;
margin-bottom: 20px;
letter-spacing: -0.5px;
}

.rules-grid {
display: grid;
grid-template-columns: repeat(2, 1fr);
gap: 14px;
}

.rule-card {
background: var(–card);
border: 1px solid var(–border);
border-radius: 6px;
padding: 16px;
}

.rule-icon { font-size: 22px; margin-bottom: 8px; display: block; }
.rule-head {
font-family: ‘Syne’, sans-serif;
font-size: 13px;
font-weight: 700;
margin-bottom: 6px;
}

.rule-body { font-size: 12.5px; color: var(–muted); line-height: 1.6; }

@keyframes fadeIn {
from { opacity: 0; transform: translateY(16px); }
to { opacity: 1; transform: translateY(0); }
}

@media (max-width: 600px) {
.stats-strip { grid-template-columns: repeat(2, 1fr); }
.day-nav { grid-template-columns: repeat(4, 1fr); }
.rules-grid { grid-template-columns: 1fr; }
.masthead { grid-template-columns: 1fr; }
.masthead-meta { text-align: left; }
.day-macros { gap: 10px; }
}
</style>

</head>
